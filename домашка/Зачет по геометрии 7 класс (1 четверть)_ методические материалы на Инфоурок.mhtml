  overflow-y: auto;
}
@media only screen and (max-width: 576px) {
  .author-info-modal {
    overflow: unset;
  }
}
.author-info-modal__head {
  display: flex;
  margin-bottom: 16px;
  gap: 24px;
}
@media only screen and (max-width: 576px) {
  .author-info-modal__head {
    align-items: center;
    margin-bottom: 13px;
    gap: 12px;
  }
}
.author-info-modal__avatar {
  width: 100%;
  height: 120px;
  max-width: 120px;
  overflow: hidden;
  border-radius: 5px;
}
@media only screen and (max-width: 576px) {
  .author-info-modal__avatar {
    height: 72px;
    max-width: 72px;
  }
}
.author-info-modal__avatar img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.author-info-modal__info {
  display: flex;
  flex-direction: column;
  width: 100%;
  gap: 12px;
}
@media only screen and (max-width: 576px) {
  .author-info-modal__info {
    gap: 8px;
  }
  .author-info-modal__info .author-info-modal__statistics {
    display: none;
  }
}
.author-info-modal__info button {
  margin-top: 0;
  width: fit-content;
}
.author-info-modal__name {
  font-weight: 700;
  font-size: 24px;
  line-height: 120%;
  letter-spacing: -0.48px;
  color: #181818;
}
@media only screen and (max-width: 576px) {
  .author-info-modal__name {
    font-size: 16px;
  }
}
.author-info-modal__items {
  display: flex;
  flex-direction: column;
  margin-bottom: 17px;
  gap: 8px;
}
@media only screen and (max-width: 576px) {
  .author-info-modal__items {
    margin-bottom: 12px;
  }
}
.author-info-modal__item {
  display: flex;
  align-items: center;
  font-weight: 400;
  font-size: 14px;
  line-height: 140%;
  color: #181818;
}
.author-info-modal__item svg {
  margin-right: 8px;
  color: #76767a;
}
.author-info-modal__item a {
  margin-left: 4px;
  font-weight: 600;
  color: #267f8c;
}
.author-info-modal__statistics {
  display: flex;
  flex-direction: column;
  gap: 9px;
}
.author-info-modal__statistics--grid {
  display: block;
  column-count: 2;
  column-gap: 20px;
}
.author-info-modal__statistics--grid p:not(:nth-child(2n)) {
  margin-bottom: 8px;
}
.author-info-modal__statistics--mobile {
  display: none;
}
@media only screen and (max-width: 576px) {
  .author-info-modal__statistics--mobile {
    display: flex;
    flex-direction: column;
    margin-bottom: 12px;
    gap: 8px;
  }
}
.author-info-modal__about {
  margin-bottom: 16px;
  font-weight: 700;
  font-size: 18px;
  line-height: 120%;
  letter-spacing: -0.36px;
  color: #181818;
}
@media only screen and (max-width: 576px) {
  .author-info-modal__about {
    margin-bottom: 12px;
    font-weight: 600;
    font-size: 16px;
